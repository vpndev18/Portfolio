# Default: treat as text, normalize to LF in the repo, native on checkout.
* text=auto eol=lf

# ── Source code (force LF — runs on Linux in CI/containers) ──────────────
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf working-tree-encoding=UTF-16LE-BOM
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
.env*       text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# ── Windows-only files (keep CRLF) ───────────────────────────────────────
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# ── Binary (never convert) ───────────────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.zip       binary
*.gz        binary
*.dll       binary
*.exe       binary
*.pfx       binary
*.snk       binary

# ── GitHub linguist hints ────────────────────────────────────────────────
Portfolio.Web/dist/**      linguist-generated
**/Migrations/**.Designer.cs linguist-generated
