# Copy to `.env.local` (gitignored) for local overrides.
#
# Leave VITE_API_URL empty to use the Vite dev proxy from vite.config.ts.
# In production, set this to the absolute URL of the API host.
#
# Examples:
#   VITE_API_URL=                          # dev (uses proxy)
#   VITE_API_URL=https://api.vallabh.dev   # prod
VITE_API_URL=
