# Copy to `.env` (in this same folder) and fill values.
# `.env` is gitignored. NEVER put real production secrets in here.
#
# Compose reads these automatically when you run `docker compose up`.

# ── Local Postgres (Docker) ──────────────────────────────
# Username and DB have safe defaults in compose; password has none — must be set.
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=replace_me_with_any_local_value
POSTGRES_DB=portfolio_dev
